# ─────────────────────────────────────────────────────
# M-Architect — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────

# ── GoDaddy / cPanel SMTP ──────────────────────────
# Your cPanel email host (usually your domain)
SMTP_HOST=mail.m-architectpvt.com

# 465 (SSL) is most reliable on GoDaddy shared hosting
SMTP_PORT=465

# The full email address you created in cPanel
SMTP_USER=info@m-architectpvt.com

# The password you set for that cPanel email account
SMTP_PASS=your_cpanel_email_password_here

# Where the contact form emails should be delivered
# Can be same as SMTP_USER, or a different inbox
CONTACT_TO=info@m-architectpvt.com
